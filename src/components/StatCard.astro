---
interface Props {
  stat: string;
  label: string;
  source?: string;
}

const { stat, label, source } = Astro.props;
---

<div class="text-center">
  <div class="font-serif font-medium text-copper mb-1" style="font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1;">
    {stat}
  </div>
  <div class="font-sans text-sm text-charcoal/80 leading-snug">
    {label}
  </div>
  {source && (
    <div class="font-sans text-xs text-charcoal/40 mt-1">{source}</div>
  )}
</div>
