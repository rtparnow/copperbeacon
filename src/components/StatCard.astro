---
interface Props {
  stat: string;
  label: string;
  source?: string;
}

const { stat, label, source } = Astro.props;
---

<div class="text-center">
  <div class="stat-number mb-1">{stat}</div>
  <div class="font-sans text-sm text-charcoal/60 leading-snug">{label}</div>
  {source && (
    <div class="font-mono text-xs text-charcoal/35 mt-1">{source}</div>
  )}
</div>
