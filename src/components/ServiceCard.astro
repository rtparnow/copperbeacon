---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
---

<div class="card group relative">
  {icon && (
    <div class="w-9 h-9 rounded border border-border flex items-center justify-center mb-4" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" class="text-copper">
        <path d={icon} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  )}
  <h3 class="font-sans font-semibold text-charcoal mb-2" style="font-size: 1rem; line-height: 1.35; letter-spacing: -0.02em;">
    {href
      ? <a href={href} class="hover:text-copper transition-colors after:absolute after:inset-0">{title}</a>
      : title
    }
  </h3>
  <p class="font-sans text-charcoal/60 text-sm leading-relaxed">
    {description}
  </p>
</div>
