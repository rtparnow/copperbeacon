---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
---

<div class="card group">
  {icon && (
    <div class="w-10 h-10 rounded-lg bg-copper/10 flex items-center justify-center mb-4" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="text-copper">
        <path d={icon} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  )}
  <h3 class="font-serif font-medium text-navy mb-2" style="font-size: 1.25rem; line-height: 1.3;">
    {href ? <a href={href} class="hover:text-copper transition-colors after:absolute after:inset-0">{title}</a> : title}
  </h3>
  <p class="font-sans text-charcoal/80 text-sm leading-relaxed">
    {description}
  </p>
</div>
