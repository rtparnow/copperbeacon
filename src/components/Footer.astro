---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/services',      label: 'Services' },
  { href: '/industries',    label: 'Industries' },
  { href: '/about',         label: 'About' },
  { href: '/blog',          label: 'Blog' },
  { href: '/case-studies',  label: 'Case Studies' },
  { href: '/contact',       label: 'Contact' },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms',   label: 'Terms of Service' },
];
---

<!-- Footer is always near-black regardless of light/dark mode -->
<footer class="bg-neutral-950 dark:bg-neutral-900 text-white/70">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-5" aria-label="Copper Beacon — home">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="14" r="14" fill="#D4904A"/>
            <path d="M8 14C8 10.686 10.686 8 14 8C15.657 8 17.157 8.672 18.243 9.757" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <circle cx="14" cy="14" r="3" fill="white"/>
            <path d="M14 7V5M14 23V21M7 14H5M23 14H21" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="font-sans font-semibold text-white text-base tracking-tight">Copper Beacon</span>
        </a>
        <p class="font-sans text-sm leading-relaxed text-white/50 max-w-xs mb-4">
          You run the business. We bring the customers.
        </p>
        <a href="mailto:hello@copperbeacon.com" class="font-sans text-sm text-white/50 hover:text-copper transition-colors duration-150">
          hello@copperbeacon.com
        </a>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-mono text-xs tracking-widest uppercase text-white/30 mb-5">Navigation</h3>
        <ul class="flex flex-col gap-2.5" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="font-sans text-sm text-white/50 hover:text-copper transition-colors duration-150"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries & CTA -->
      <div>
        <h3 class="font-mono text-xs tracking-widest uppercase text-white/30 mb-5">Industries</h3>
        <ul class="flex flex-col gap-2.5 mb-8" role="list">
          {[
            'Dentists & Dental Practices',
            'Orthodontists',
            'Chiropractors',
            'Lawyers',
            'Plumbers & HVAC',
            'Electricians & Roofers',
          ].map((industry) => (
            <li>
              <a href="/industries" class="font-sans text-sm text-white/50 hover:text-copper transition-colors duration-150">
                {industry}
              </a>
            </li>
          ))}
        </ul>
        <a href="/contact" class="btn-primary text-sm px-4 py-2">
          Book a free call
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-14 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-white/30">
        &copy; {currentYear} Copper Beacon. Based in Iowa. All rights reserved.
      </p>
      <ul class="flex items-center gap-6" role="list">
        {legalLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="font-sans text-xs text-white/30 hover:text-white/60 transition-colors duration-150">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
