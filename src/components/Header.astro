---
const navLinks = [
  { href: '/services',   label: 'Services' },
  { href: '/industries', label: 'Industries' },
  { href: '/about',      label: 'About' },
  { href: '/blog',       label: 'Blog' },
];

const currentPath = Astro.url.pathname;

function navClass(href: string) {
  const active = currentPath.startsWith(href);
  return [
    'px-3 py-1.5 font-sans text-sm font-medium transition-colors duration-150 rounded',
    active
      ? 'text-copper'
      : 'text-charcoal/60 hover:text-charcoal',
  ].join(' ');
}
---

<a href="#main-content" class="skip-to-content">Skip to content</a>

<!-- Sticky header: transparent bg + backdrop blur + 1px bottom border -->
<header
  class="sticky top-0 z-40 border-b border-border bg-cream/80 backdrop-blur-sm"
  id="site-header"
>
  <div class="container">
    <nav class="flex items-center justify-between h-14" aria-label="Main navigation">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 group" aria-label="Copper Beacon — home">
        <!-- Beacon icon -->
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="text-copper">
          <circle cx="14" cy="14" r="14" fill="currentColor"/>
          <path d="M8 14C8 10.686 10.686 8 14 8C15.657 8 17.157 8.672 18.243 9.757" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <circle cx="14" cy="14" r="3" fill="white"/>
          <path d="M14 7V5M14 23V21M7 14H5M23 14H21" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="font-sans font-semibold text-charcoal text-base tracking-tight">
          Copper Beacon
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-0.5" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={navClass(href)}
              aria-current={currentPath.startsWith(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: dark mode toggle + CTA + mobile menu -->
      <div class="flex items-center gap-2">

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          class="p-2 text-charcoal/50 hover:text-charcoal rounded transition-colors duration-150"
          aria-label="Toggle dark mode"
          title="Toggle dark mode"
        >
          <!-- Moon (shown in light mode) -->
          <svg id="icon-moon" width="17" height="17" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M17.5 13.2A8 8 0 019.8 2.5a8 8 0 100 15 8 8 0 007.7-4.3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <!-- Sun (shown in dark mode) -->
          <svg id="icon-sun" class="hidden" width="17" height="17" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.22 4.22l1.42 1.42M14.36 14.36l1.42 1.42M4.22 15.78l1.42-1.42M14.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <a href="/contact" class="hidden sm:inline-flex btn-primary text-sm px-4 py-2">
          Book a free call
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 text-charcoal/60 hover:text-charcoal rounded transition-colors duration-150"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" id="menu-icon-open">
            <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" id="menu-icon-close" class="hidden">
            <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-cream">
    <div class="container py-4">
      <ul class="flex flex-col gap-0.5" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class={navClass(href)}>{label}</a>
          </li>
        ))}
        <li class="pt-3 border-t border-border mt-3">
          <a href="/contact" class="btn-primary w-full justify-center">
            Book a free call
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  // ─── Mobile menu toggle ──────────────────────────────────────────────────
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // ─── Dark mode toggle ────────────────────────────────────────────────────
  const themeBtn = document.getElementById('theme-toggle');
  const moonIcon = document.getElementById('icon-moon');
  const sunIcon  = document.getElementById('icon-sun');

  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    moonIcon?.classList.toggle('hidden', dark);
    sunIcon?.classList.toggle('hidden', !dark);
    try { localStorage.setItem('cb-theme', dark ? 'dark' : 'light'); } catch (_) {}
  }

  // Sync icon state on load
  applyTheme(document.documentElement.classList.contains('dark'));

  themeBtn?.addEventListener('click', () => {
    applyTheme(!document.documentElement.classList.contains('dark'));
  });
</script>
