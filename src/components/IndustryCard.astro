---
interface Props {
  industry: string;
  description: string;
  website?: string;
  websiteLabel?: string;
}

const { industry, description, website, websiteLabel } = Astro.props;
---

<div class="card flex flex-col">
  <h3 class="font-sans font-semibold text-charcoal mb-2" style="font-size: 1rem; line-height: 1.35; letter-spacing: -0.02em;">
    {industry}
  </h3>
  <p class="font-sans text-charcoal/60 text-sm leading-relaxed flex-grow mb-4">
    {description}
  </p>
  {website && websiteLabel && (
    <a
      href={`https://${website}`}
      class="font-sans text-sm font-medium text-copper hover:text-copper-dark transition-colors duration-150 inline-flex items-center gap-1"
      target="_blank"
      rel="noopener noreferrer"
    >
      {websiteLabel}
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  )}
</div>
