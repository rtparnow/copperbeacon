---
interface Props {
  heading?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading = 'Ready to let the customers find you?',
  body = 'Fifteen minutes. No pitch. Just a real conversation about whether we can help.',
  ctaLabel = 'Book a free 15-minute call',
  ctaHref = '[BOOKING_URL]',
} = Astro.props;
---

<section class="bg-navy py-20" aria-labelledby="cta-heading">
  <div class="container text-center">
    <h2 id="cta-heading" class="font-serif font-medium text-cream mb-4" style="font-size: clamp(1.75rem, 3vw, 2.75rem); line-height: 1.2;">
      {heading}
    </h2>
    <p class="font-sans text-cream/70 text-lg max-w-md mx-auto mb-8">
      {body}
    </p>
    <a href={ctaHref} class="btn-primary-reversed">
      {ctaLabel}
    </a>
  </div>
</section>
