---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog | Notes on Local Marketing & AI Search | Copper Beacon"
  description="Practical writing for business owners who don't have time to read another fluff-filled agency blog. Local SEO, Google Business Profile, AI search, and more."
>
  <!-- Hero -->
  <section class="bg-cream py-20" aria-labelledby="blog-hero-heading">
    <div class="container">
      <div class="max-w-2xl">
        <h1
          id="blog-hero-heading"
          class="font-serif font-medium text-navy mb-6"
          style="font-size: clamp(2.25rem, 4vw, 3.5rem); line-height: 1.1; letter-spacing: -0.02em;"
        >
          Notes on local marketing, AI search, and growing a local business.
        </h1>
        <p class="font-sans text-charcoal" style="font-size: 1.125rem; line-height: 1.65;">
          Practical writing for business owners who don't have time to read another fluff-filled agency blog.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts or empty state -->
  <section class="bg-warm-white py-16 border-t border-border">
    <div class="container">
      {posts.length === 0 ? (
        <div class="max-w-prose">
          <div class="card py-12 text-center">
            <div class="w-12 h-12 rounded-full bg-copper/10 flex items-center justify-center mx-auto mb-4" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M4 6h14M4 10h10M4 14h6" stroke="#B87333" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </div>
            <h2 class="font-serif font-medium text-navy mb-3" style="font-size: 1.25rem;">Articles coming soon.</h2>
            <p class="font-sans text-charcoal/70 text-sm leading-relaxed max-w-sm mx-auto">
              We're building a library of practical guides — on local SEO, Google Business Profile, AI search optimization, and what small business owners actually need to know. In the meantime, <a href="/contact" class="text-copper hover:text-copper-dark underline underline-offset-2 transition-colors">book a call</a> if you have questions about your specific business.
            </p>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="card group">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="pill text-xs">{tag}</span>
                ))}
              </div>
              <h2 class="font-serif font-medium text-navy mb-2 group-hover:text-copper transition-colors" style="font-size: 1.125rem; line-height: 1.3;">
                <a href={`/blog/${post.slug}`} class="after:absolute after:inset-0">
                  {post.data.title}
                </a>
              </h2>
              <p class="font-sans text-sm text-charcoal/70 leading-relaxed mb-4">
                {post.data.description}
              </p>
              <time
                datetime={post.data.publishDate.toISOString()}
                class="font-sans text-xs text-charcoal/50"
              >
                {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
