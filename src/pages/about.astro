---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="About Copper Beacon | Founder-Led Local Marketing"
  description="Founded by an engineer who grew a home services business to nearly $800k. Copper Beacon is built on real operator experience and honest technical marketing work."
>
  <!-- Hero -->
  <section class="bg-cream py-20" aria-labelledby="about-hero-heading">
    <div class="container">
      <div class="max-w-3xl">
        <h1
          id="about-hero-heading"
          class="font-sans font-semibold text-charcoal mb-6"
          style="font-size: clamp(2.25rem, 4vw, 3.5rem); line-height: 1.1; letter-spacing: -0.02em;"
        >
          A real person, handling your marketing.
        </h1>
        <p class="font-sans text-charcoal" style="font-size: 1.125rem; line-height: 1.65;">
          No account managers. No offshore teams. No sales pitch. Just one engineer doing the technical marketing work your business needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Founder story -->
  <section class="bg-warm-white py-20 border-t border-border" aria-labelledby="founder-heading">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Headshot -->
        <div class="lg:col-span-2">
          <div
            class="aspect-[3/4] rounded-card bg-border/30 flex items-center justify-center border border-border"
            aria-label="[FOUNDER_NAME] — founder of Copper Beacon (photo placeholder)"
            role="img"
          >
            <div class="text-center text-charcoal/40">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="mx-auto mb-3" aria-hidden="true">
                <circle cx="24" cy="18" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="M8 42c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <p class="font-sans text-xs">[FOUNDER_HEADSHOT]</p>
            </div>
          </div>
        </div>

        <!-- Bio -->
        <div class="lg:col-span-3">
          <h2 id="founder-heading" class="section-heading mb-8">Why Copper Beacon exists.</h2>
          <div class="flex flex-col gap-5 font-sans text-charcoal leading-relaxed">
            <p>
              I'm [FOUNDER_NAME], an engineer by training. Before starting Copper Beacon, I built and grew a home services business to nearly $800,000 in revenue. I learned firsthand what small business owners actually need when it comes to marketing — and more importantly, what they don't need.
            </p>
            <p>
              What they don't need: agencies that speak in jargon, send vague monthly reports, and charge for "strategy" meetings that go nowhere. What they don't need: someone who's never run a business telling them how to run theirs.
            </p>
            <p>
              What they do need: someone technical, competent, and accountable who handles the search visibility, Google Business Profile, reviews, and online reputation work — so the business owner can focus on the actual business.
            </p>
            <p>
              That's what Copper Beacon is. No pitch decks. No long-term contracts. Just honest technical work that brings more customers in the door.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operator-led advantage -->
  <section class="bg-cream py-20 border-t border-border" aria-labelledby="operator-heading">
    <div class="container">
      <div class="max-w-prose">
        <h2 id="operator-heading" class="section-heading mb-6">Why operator experience matters.</h2>
        <p class="font-sans text-charcoal leading-relaxed">
          Most marketing agencies are started by marketers. That sounds obvious — until you realize that marketers often haven't run a service business, hired crews, managed cash flow, or lost sleep over a slow month. Copper Beacon is different: the founder spent years operating a service business before moving into digital marketing. That changes what we build, what we recommend, and how we talk to clients.
        </p>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="bg-warm-white py-20 border-t border-border" aria-labelledby="approach-heading">
    <div class="container">
      <h2 id="approach-heading" class="section-heading mb-12">How we work.</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-copper/10 flex items-center justify-center mb-4" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2v4M9 12v4M2 9h4M12 9h4" stroke="#B87333" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="2.5" stroke="#B87333" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-3" style="font-size: 1.25rem;">Transparent</h3>
          <p class="font-sans text-charcoal/80 text-sm leading-relaxed">
            Clear deliverables, honest reporting, no mystery charges. You always know what's being done and what it's producing.
          </p>
        </div>

        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-copper/10 flex items-center justify-center mb-4" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 14l4-5 3 3 4-7" stroke="#B87333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-3" style="font-size: 1.25rem;">Measured</h3>
          <p class="font-sans text-charcoal/80 text-sm leading-relaxed">
            We optimize for outcomes that matter — calls, bookings, revenue — not vanity metrics like traffic spikes and keyword rankings.
          </p>
        </div>

        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-copper/10 flex items-center justify-center mb-4" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2a7 7 0 100 14A7 7 0 009 2z" stroke="#B87333" stroke-width="1.5"/>
              <path d="M9 5v4l2.5 2.5" stroke="#B87333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-sans font-semibold text-charcoal mb-3" style="font-size: 1.25rem;">Steady</h3>
          <p class="font-sans text-charcoal/80 text-sm leading-relaxed">
            Local SEO and AI search visibility are long games. We focus on compounding results month over month, not overnight wins that don't last.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
