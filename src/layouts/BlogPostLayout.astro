---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, publishDate, updatedDate, author, tags } = post.data;

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Copper Beacon',
    url: 'https://copperbeacon.com',
  },
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://copperbeacon.com' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://copperbeacon.com/blog' },
    { '@type': 'ListItem', position: 3, name: title, item: new URL(Astro.url.pathname, Astro.site).href },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  schema={[articleSchema, breadcrumbSchema]}
>
  <article class="py-20">
    <div class="container">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 font-sans text-sm text-charcoal/60" role="list">
          <li><a href="/" class="hover:text-copper transition-colors">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li><a href="/blog" class="hover:text-copper transition-colors">Blog</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="text-charcoal" aria-current="page">{title}</li>
        </ol>
      </nav>

      <div class="max-w-prose mx-auto">
        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map((tag) => (
              <span class="pill">{tag}</span>
            ))}
          </div>
        )}

        <h1 class="font-sans font-semibold text-charcoal mb-6" style="font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; letter-spacing: -0.02em;">
          {title}
        </h1>

        <div class="flex items-center gap-4 font-sans text-sm text-charcoal/60 mb-8 pb-8 border-b border-border">
          <span>By {author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={publishDate.toISOString()}>
            {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
        </div>

        <div class="prose prose-lg max-w-none font-sans text-charcoal leading-relaxed">
          <slot />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
